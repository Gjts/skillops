{
  "schemaVersion": 1,
  "id": "local-prompt-quality",
  "name": "Local Prompt quality",
  "version": "1.1.0",
  "owner": "skillops-maintainers",
  "sensitivity": "synthetic",
  "artifactKind": "prompt",
  "repeats": 2,
  "cases": [
    {
      "id": "concise-summary",
      "input": "Summarize the release status in two sentences.",
      "variables": {
        "audience": "engineering leaders",
        "channel": "an internal status update"
      },
      "weight": 1,
      "assertions": [
        { "type": "not-contains", "value": "API_KEY", "label": "no-secret-placeholder" },
        { "type": "icontains", "value": "status", "label": "mentions-status", "blocking": false },
        { "type": "icontains", "value": "release", "label": "mentions-release", "blocking": false },
        { "type": "icontains", "value": "ready", "label": "states-readiness", "blocking": false },
        { "type": "icontains", "value": "verified", "label": "states-verification", "blocking": false }
      ]
    }
  ]
}
